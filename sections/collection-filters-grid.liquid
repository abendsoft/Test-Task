{% comment %}
  Collection Filters Grid - Independent section
  Uses Search & Discovery (Price, Colors, Size). Own CSS/JS.
{% endcomment %}

{{ 'collection-filters-grid.css' | asset_url | stylesheet_tag }}
<script src="{{ 'collection-filters-grid.js' | asset_url }}" defer></script>

{%- paginate collection.products by section.settings.products_per_page -%}
  {%- assign heading_text = section.settings.heading | default: collection.title -%}
  {%- assign start_item = paginate.current_offset | plus: 1 -%}
  {%- assign end_item = paginate.current_offset | plus: collection.products.size -%}
  {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}

  <div class="cfg-collection-grid">
    <aside class="cfg-sidebar" id="cfg-filters-sidebar">
      {% render 'cfg-filters', collection: collection %}
    </aside>

    <div class="cfg-main">
      <div class="cfg-header-row">
        <div class="cfg-heading-row">
          <h1 class="cfg-title">{{ heading_text }}</h1>
          <button type="button" class="cfg-mobile-filter-btn" aria-label="Open filters">
            <svg width="24" height="24" viewBox="0 0 20 20" fill="none"><path fill="currentColor" d="M4.833 6.5a1.667 1.667 0 1 1 3.334 0 1.667 1.667 0 0 1-3.334 0M4.05 7H2.5a.5.5 0 0 1 0-1h1.55a2.5 2.5 0 0 1 4.9 0h8.55a.5.5 0 0 1 0 1H8.95a2.5 2.5 0 0 1-4.9 0m11.117 6.5a1.667 1.667 0 1 0-3.334 0 1.667 1.667 0 0 0 3.334 0"/></svg>
          </button>
        </div>
        <div class="cfg-header-right">
          <span class="cfg-count">Showing {{ start_item }}-{{ end_item }} of {{ paginate.items }} Products</span>
          <div class="cfg-sort">
            <label for="cfg-sort">Sort by:</label>
            <select id="cfg-sort" form="cfg-filter-form" name="sort_by">
              {%- for option in collection.sort_options -%}
                <option value="{{ option.value | escape }}"{% if option.value == sort_by %} selected{% endif %}>{{ option.name | escape }}</option>
              {%- endfor -%}
            </select>
          </div>
        </div>
      </div>

      {%- if collection.products.size == 0 -%}
        <p class="cfg-empty">No products found. Try fewer filters.</p>
      {%- else -%}
        <ul class="cfg-product-grid">
          {%- for product in collection.products -%}
            <li>
              <a href="{{ product.url }}" class="cfg-product-card">
                <div class="cfg-product-image">
                  {%- if product.featured_media -%}
                    <img src="{{ product.featured_media | image_url: width: 600 }}" alt="{{ product.featured_media.alt | escape }}" loading="{% if forloop.index > 4 %}lazy{% else %}eager{% endif %}">
                  {%- else -%}
                    <img src="{{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder' }}" alt="">
                  {%- endif -%}
                </div>
                <h3 class="cfg-product-title">{{ product.title }}</h3>
                <div class="cfg-product-price">
                  {%- if product.compare_at_price > product.price -%}
                    <s>{{ product.compare_at_price | money }}</s> {{ product.price | money }}
                    {%- assign percent = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
                    <span class="cfg-product-badge">-{{ percent }}%</span>
                  {%- else -%}
                    {{ product.price | money }}
                  {%- endif -%}
                </div>
              </a>
            </li>
          {%- endfor -%}
        </ul>

        {%- if paginate.pages > 1 -%}
          <div class="cfg-pagination-wrap">
            <nav class="cfg-pagination" aria-label="Pagination">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" class="cfg-pagination-prev">← Previous</a>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}">{{ part.title }}</a>
                {%- else -%}
                  {%- if part.title == paginate.current_page -%}
                    <span class="cfg-page-current" aria-current="page">{{ part.title }}</span>
                  {%- else -%}
                    <span>{{ part.title }}</span>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" class="cfg-pagination-next">Next →</a>
              {%- endif -%}
            </nav>
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>

  <script>
    (function() {
      var btn = document.querySelector('.cfg-mobile-filter-btn');
      var sidebar = document.getElementById('cfg-filters-sidebar');
      if (btn && sidebar) {
        btn.addEventListener('click', function() {
          sidebar.classList.toggle('cfg-sidebar--open');
          sidebar.setAttribute('aria-hidden', sidebar.classList.contains('cfg-sidebar--open') ? 'false' : 'true');
        });
      }
      var sortSelect = document.querySelector('.cfg-sort select');
      var form = document.getElementById('cfg-filter-form');
      if (sortSelect && form) {
        sortSelect.addEventListener('change', function() { form.submit(); });
      }
    })();
  </script>
{%- endpaginate -%}

{% schema %}
{
  "name": "Collection filters grid",
  "class": "section",
  "templates": ["collection"],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave blank to use collection title"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 36,
      "step": 2,
      "default": 10,
      "label": "Products per page"
    }
  ]
}
{% endschema %}

{% comment %}
  Filter form for Collection Filters Grid.
  Price: dual-handle range slider. Colors: circular swatches. Size: pills.
  Uses Search & Discovery filters.
{% endcomment %}

{%- liquid
  if collection.url
    assign form_action = collection.url
  else
    assign form_action = routes.search_url
  endif
-%}

<form action="{{ form_action }}" method="get" id="cfg-filter-form" class="cfg-filters-form">
  {%- if collection.terms -%}
    <input type="hidden" name="q" value="{{ collection.terms | escape }}">
  {%- endif -%}

  <div class="cfg-filters-inner">
    <div class="cfg-filters-header">
      <h2 class="cfg-filters-title">Filters</h2>
      <span class="cfg-filters-icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 20 20" fill="none"><path fill="currentColor" d="M4.833 6.5a1.667 1.667 0 1 1 3.334 0 1.667 1.667 0 0 1-3.334 0M4.05 7H2.5a.5.5 0 0 1 0-1h1.55a2.5 2.5 0 0 1 4.9 0h8.55a.5.5 0 0 1 0 1H8.95a2.5 2.5 0 0 1-4.9 0m11.117 6.5a1.667 1.667 0 1 0-3.334 0 1.667 1.667 0 0 0 3.334 0"/></svg>
      </span>
    </div>

    {%- for filter in collection.filters -%}
      {%- assign filter_label_down = filter.label | downcase -%}
      {%- assign is_color = false -%}
      {%- if filter_label_down contains 'color' -%}
        {%- assign is_color = true -%}
      {%- endif -%}

      <div class="cfg-filter-group">
        <div class="cfg-filter-divider"></div>
        <details class="cfg-filter-details" open>
          <summary class="cfg-filter-summary">
            <span class="cfg-filter-label">{{ filter.label }}</span>
            <svg class="cfg-filter-caret" width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="2"/></svg>
          </summary>
          <div class="cfg-filter-content">
            {% case filter.type %}
              {% when 'price_range' %}
                {%- assign min_val = filter.min_value.value | default: 0 | divided_by: 100.0 -%}
                {%- assign max_val = filter.max_value.value | default: filter.range_max | divided_by: 100.0 -%}
                <div class="cfg-price-slider-wrap" data-range-max="{{ filter.range_max }}" data-param-min="{{ filter.min_value.param_name }}" data-param-max="{{ filter.max_value.param_name }}">
                  <div class="cfg-price-slider-track">
                    <span class="cfg-price-slider-fill" aria-hidden="true"></span>
                    <input type="range" class="cfg-price-slider cfg-price-slider-min" min="0" max="{{ filter.range_max }}" value="{{ filter.min_value.value | default: 0 }}" step="100">
                    <input type="range" class="cfg-price-slider cfg-price-slider-max" min="0" max="{{ filter.range_max }}" value="{{ filter.max_value.value | default: filter.range_max }}" step="100">
                  </div>
                  <div class="cfg-price-slider-values">
                    <span class="cfg-price-min-display">{{ min_val | money }}</span>
                    <span class="cfg-price-max-display">{{ max_val | money }}</span>
                  </div>
                  <input type="hidden" name="{{ filter.min_value.param_name }}" value="{{ filter.min_value.value | default: '' }}">
                  <input type="hidden" name="{{ filter.max_value.param_name }}" value="{{ filter.max_value.value | default: '' }}">
                </div>
              {% when 'list', 'boolean' %}
                {% assign use_swatches = false %}
                {% if is_color %}{% assign use_swatches = true %}{% endif %}
                {% if filter.presentation == 'swatch' %}{% assign use_swatches = true %}{% endif %}
                <ul class="cfg-filter-values {% if use_swatches %}cfg-filter--swatch{% else %}cfg-filter--pill{% endif %}">
                  {%- for value in filter.values -%}
                    {% assign disabled = false %}
                    {%- if value.count == 0 and value.active == false -%}
                      {% assign disabled = true %}
                    {%- endif -%}
                    <li class="cfg-filter-value{% if value.active %} cfg-filter-value--active{% endif %}{% if disabled %} cfg-filter-value--disabled{% endif %}">
                      {%- if use_swatches -%}
                        {%- assign swatch_style = '' -%}
                        {%- if value.swatch and value.swatch.color -%}
                          {%- assign swatch_style = 'background-color:' | append: value.swatch.color -%}
                        {%- elsif value.swatch and value.swatch.image -%}
                          {%- assign swatch_style = 'background-image:url(' | append: value.swatch.image | image_url: width: 40 | append: ');background-size:cover;' -%}
                        {%- else -%}
                          {%- assign lbl = value.label | downcase | strip -%}
                          {%- if lbl == 'green' -%}{%- assign swatch_style = 'background-color:#22c55e' -%}
                          {%- elsif lbl == 'red' -%}{%- assign swatch_style = 'background-color:#ef4444' -%}
                          {%- elsif lbl == 'yellow' -%}{%- assign swatch_style = 'background-color:#eab308' -%}
                          {%- elsif lbl == 'orange' -%}{%- assign swatch_style = 'background-color:#f97316' -%}
                          {%- elsif lbl == 'blue' -%}{%- assign swatch_style = 'background-color:#3b82f6' -%}
                          {%- elsif lbl == 'cyan' or lbl == 'sky blue' -%}{%- assign swatch_style = 'background-color:#06b6d4' -%}
                          {%- elsif lbl == 'purple' -%}{%- assign swatch_style = 'background-color:#a855f7' -%}
                          {%- elsif lbl == 'pink' -%}{%- assign swatch_style = 'background-color:#ec4899' -%}
                          {%- elsif lbl == 'white' -%}{%- assign swatch_style = 'background-color:#ffffff;border:1px solid #e5e5e5' -%}
                          {%- elsif lbl == 'black' -%}{%- assign swatch_style = 'background-color:#000000' -%}
                          {%- elsif lbl == 'dawn' -%}{%- assign swatch_style = 'background-color:#fef3c7' -%}
                          {%- elsif lbl == 'electric' -%}{%- assign swatch_style = 'background-color:#facc15' -%}
                          {%- elsif lbl == 'ice' -%}{%- assign swatch_style = 'background-color:#e0f2fe' -%}
                          {%- elsif lbl == 'powder' -%}{%- assign swatch_style = 'background-color:#fce7f3' -%}
                          {%- elsif lbl == 'sunset' -%}{%- assign swatch_style = 'background-color:#fb923c' -%}
                          {%- else -%}{%- assign swatch_style = 'background-color:#e0e0e0' -%}
                          {%- endif -%}
                        {%- endif -%}
                        <label class="cfg-swatch">
                          <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}"
                            {% if value.active %}checked{% endif %}{% if disabled %} disabled{% endif %}>
                          <span class="cfg-swatch-circle" style="{{ swatch_style }}"></span>
                          <span class="cfg-swatch-check">
                            <svg width="12" height="10" viewBox="0 0 12 10" fill="none"><path d="M1 5l3 3 7-7" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                          </span>
                        </label>
                      {%- else -%}
                        <label class="cfg-pill">
                          <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}"
                            {% if value.active %}checked{% endif %}{% if disabled %} disabled{% endif %}>
                          <span>{{ value.label }} ({{ value.count }})</span>
                        </label>
                      {%- endif -%}
                    </li>
                  {%- endfor -%}
                </ul>
            {% endcase %}
          </div>
        </details>
      </div>
    {%- endfor -%}

    <div class="cfg-filter-actions">
      <a href="{{ form_action }}" class="cfg-clear-filters">Clear filters</a>
      <button type="submit" class="cfg-apply-btn">Apply Filter</button>
    </div>
  </div>
</form>
